<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VibeCoders.Views.AchievementsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VibeCoders.Models"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border
            Grid.Row="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,20">
            <StackPanel Spacing="4">
                <TextBlock
                    Text="Achievements"
                    Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock
                    Text="Track your progress and unlock badges as you hit new milestones."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Scrollable grid body -->
        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="24,24,24,40" Spacing="16">

                <!-- Loading state -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ProgressRing IsActive="True" Width="40" Height="40" />
                    <TextBlock
                        Text="Loading achievements..."
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Achievement grid -->
                <ItemsRepeater
                    ItemsSource="{x:Bind ViewModel.Achievements, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinItemWidth="200"
                            MinItemHeight="200"
                            MinRowSpacing="16"
                            MinColumnSpacing="16"
                            ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:Achievement">
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="20">
                                <!-- Dim the card when locked -->
                                <Border.Opacity>
                                    <Binding Path="IsUnlocked"
                                             Converter="{StaticResource BoolToOpacity}" />
                                </Border.Opacity>
                                <StackPanel Spacing="12" HorizontalAlignment="Center">

                                    <!-- Icon circle -->
                                    <Border
                                        Width="64" Height="64"
                                        CornerRadius="32"
                                        HorizontalAlignment="Center"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                        <FontIcon
                                            Glyph="{x:Bind Icon}"
                                            FontSize="28"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Name -->
                                    <TextBlock
                                        Text="{x:Bind Name}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center" />

                                    <!-- Description -->
                                    <TextBlock
                                        Text="{x:Bind Description}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center" />

                                    <!-- Locked / Unlocked badge -->
                                    <Border
                                        CornerRadius="4"
                                        Padding="8,4"
                                        HorizontalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{ThemeResource SystemFillColorSuccessBackground}" />
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                Glyph="&#xE73E;"
                                                FontSize="11"
                                                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                            <TextBlock
                                                Text="Unlocked"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                Visibility="{x:Bind IsUnlocked}" />
                                            <FontIcon
                                                Glyph="&#xE72E;"
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Visibility="{x:Bind IsUnlocked, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                                            <TextBlock
                                                Text="Locked"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Visibility="{x:Bind IsUnlocked, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
