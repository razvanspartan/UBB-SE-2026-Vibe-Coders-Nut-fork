<UserControl
    x:Class="VibeCoders.Views.CreateWorkoutView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VibeCoders.Models"
    mc:Ignorable="d"
    d:DesignHeight="700"
    d:DesignWidth="1100">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
        <StackPanel Spacing="8">
            <TextBlock Text="Workout Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBox Text="{Binding WorkoutName, Mode=TwoWay}"
                     PlaceholderText="e.g., Heavy Push Day - Block 1" />
        </StackPanel>

        <Rectangle Grid.Row="1" Height="1"
                   Fill="{ThemeResource ControlStrokeColorDefaultBrush}" />

        <StackPanel Grid.Row="2" Spacing="16">
            <TextBlock Text="Exercises in this Workout" Style="{StaticResource BodyStrongTextBlockStyle}" />

            <ListView Height="150"
                      Background="{ThemeResource LayerFillColorDefaultBrush}"
                      CornerRadius="4"
                      Padding="4"
                      HorizontalContentAlignment="Stretch"
                      ItemsSource="{Binding Exercises}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:TemplateExercise">
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="(" Foreground="Gray"/>
                                <TextBlock Text="{x:Bind TargetSets}" Foreground="Gray"/>
                                <TextBlock Text="×" Foreground="Gray"/>
                                <TextBlock Text="{x:Bind TargetReps}" Foreground="Gray"/>
                                <TextBlock Text=")" Foreground="Gray"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Remove"
                                    Click="RemoveExercise_Click"
                                    Tag="{x:Bind}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid ColumnSpacing="8" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ComboBox Grid.Row="0" Grid.Column="0"
                          Header="Select Exercise"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Choose..."
                          ItemsSource="{Binding AvailableExercises}"
                          SelectedItem="{Binding SelectedNewExercise, Mode=TwoWay}" />

                <NumberBox Grid.Row="0" Grid.Column="1"
                           Header="Sets"
                           Minimum="1"
                           Maximum="10"
                           SpinButtonPlacementMode="Hidden"
                           Value="{Binding NewExerciseSets, Mode=TwoWay}" />

                <NumberBox Grid.Row="0" Grid.Column="2"
                           Header="Reps"
                           Minimum="1"
                           Maximum="100"
                           SpinButtonPlacementMode="Hidden"
                           Value="{Binding NewExerciseReps, Mode=TwoWay}" />

                <Button Grid.Row="1" Grid.ColumnSpan="4"
                        Content="+ Add to Routine"
                        HorizontalAlignment="Stretch"
                        Command="{Binding AddExerciseCommand}" />
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>