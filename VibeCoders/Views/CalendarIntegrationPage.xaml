<Page
    x:Class="VibeCoders.Views.CalendarIntegrationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VibeCoders.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Calendar Integration" Style="{ThemeResource TitleTextBlockStyle}"/>
            
            <TextBlock Text="Set up your workout calendar by selecting your workout, duration, and the days you want to train." TextWrapping="Wrap" />

            <!-- Status Message InfoBar -->
            <InfoBar x:Name="StatusInfoBar" IsOpen="False" Margin="0,0,0,8"/>

            <!-- Workout Selector Dropdown -->
            <ComboBox x:Name="WorkoutComboBox" Header="Select Workout" PlaceholderText="Choose a workout program" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Full Body Strength"/>
                <ComboBoxItem Content="Cardio Blast"/>
                <ComboBoxItem Content="Yoga &amp; Flexibility"/>
                <ComboBoxItem Content="Core Crusher"/>
            </ComboBox>

            <!-- Duration Input (1-52 weeks) -->
            <TextBox x:Name="DurationWeeksTextBox" Header="Schedule Duration (Weeks)" PlaceholderText="Enter weeks (1-52)" HorizontalAlignment="Stretch" InputScope="Number"/>

            <!-- Days of the Week Selection (Multi-select) -->
            <TextBlock Text="Training Days" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ToggleButton x:Name="DayMonday" Content="Mon" />
                <ToggleButton x:Name="DayTuesday" Content="Tue" />
                <ToggleButton x:Name="DayWednesday" Content="Wed" />
                <ToggleButton x:Name="DayThursday" Content="Thu" />
                <ToggleButton x:Name="DayFriday" Content="Fri" />
                <ToggleButton x:Name="DaySaturday" Content="Sat" />
                <ToggleButton x:Name="DaySunday" Content="Sun" />
            </StackPanel>

            <!-- Generate Calendar Action Button -->
            <Button x:Name="GenerateCalendarButton" Content="Generate Calendar" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,16,0,0" Click="GenerateCalendarButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
