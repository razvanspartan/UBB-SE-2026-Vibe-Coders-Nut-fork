<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VibeCoders.Views.RankShowcasePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VibeCoders.Models"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,20,28,40" Spacing="24">

            <!-- ── Header row ────────────────────────────────────────────── -->
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        Text="Rank Showcase"
                        Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock
                        Text="Your dynamic level and achievement history"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ── Hero rank card ─────────────────────────────────────────
                 Displays "Level 5: Elite" prominently with lifetime time
                 and a progress bar toward the next rank.                  -->
            <Border
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="28,24">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                    <!-- Trophy icon + combined level/rank line -->
                    <StackPanel
                        Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
                        <Border
                            Width="52" Height="52"
                            CornerRadius="26"
                            Background="White"
                            Opacity="0.15">
                            <FontIcon
                                Glyph="&#xE8A4;"
                                FontSize="28"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="Your Rank"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="White"
                                Opacity="0.75" />
                            <!-- "Level 5: Elite" – the primary display required by #176 -->
                            <TextBlock
                                Text="{x:Bind ViewModel.LevelDisplayLine, Mode=OneWay}"
                                Style="{StaticResource TitleLargeTextBlockStyle}"
                                Foreground="White" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Lifetime active time -->
                    <StackPanel
                        Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="0,20,0,0">
                        <FontIcon Glyph="&#xE916;" FontSize="14" Foreground="White" Opacity="0.75" VerticalAlignment="Center" />
                        <TextBlock
                            Text="Lifetime active time"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="White"
                            Opacity="0.75"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Text="{x:Bind ViewModel.TotalActiveTimeDisplay, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Foreground="White"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle
                        Grid.Row="2"
                        Height="1"
                        Fill="White"
                        Opacity="0.2"
                        Margin="0,16,0,0" />

                    <!-- Progress bar (hidden at max rank) -->
                    <StackPanel
                        Grid.Row="3"
                        Spacing="8"
                        Margin="0,16,0,0"
                        Visibility="{x:Bind ViewModel.HasNextRank, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <TextBlock
                                Text="Progress to next rank"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="White"
                                Opacity="0.75" />
                            <TextBlock
                                HorizontalAlignment="Right"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="White">
                                <Run Text="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" /><Run Text="%" />
                            </TextBlock>
                        </Grid>
                        <ProgressBar
                            Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                            Minimum="0"
                            Maximum="100"
                            Height="8"
                            Background="White"
                            Opacity="0.3" />
                    </StackPanel>

                    <!-- Next rank goal line -->
                    <TextBlock
                        Grid.Row="4"
                        Text="{x:Bind ViewModel.NextRankInfo, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="White"
                        Opacity="0.85"
                        TextWrapping="Wrap"
                        Margin="0,12,0,0" />

                </Grid>
            </Border>

            <!-- ── All tier thresholds reference card ────────────────────
                 Shows every rank level so users understand what to aim for. -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Rank Tiers"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="Novice → Beginner (1h)  ·  Regular (10h)  ·  Dedicated (50h)  ·  Elite (200h)"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- ── Achievement showcase header ───────────────────────────── -->
            <StackPanel Spacing="4">
                <TextBlock
                    Text="Achievement Showcase"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Locked goals stay listed so you can always see what is next."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!-- Loading indicator -->
            <ProgressRing
                Width="28"
                Height="28"
                HorizontalAlignment="Left"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

            <!-- ── Achievement cards ──────────────────────────────────────
                 One card per AchievementShowcaseItem.
                 Shows badge title, description, exact criteria, and a
                 visual lock / unlock icon.                                -->
            <ItemsControl ItemsSource="{x:Bind ViewModel.ShowcaseAchievements, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:AchievementShowcaseItem">
                        <Border
                            Margin="0,0,0,8"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Lock / unlock icon -->
                                <Border
                                    Grid.Column="0"
                                    Width="44" Height="44"
                                    CornerRadius="22"
                                    VerticalAlignment="Center">
                                    <!-- Unlocked: filled accent circle -->
                                    <Border
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="22"
                                        Visibility="{x:Bind IsUnlocked, Converter={StaticResource BoolToVisibility}}">
                                        <FontIcon
                                            Glyph="&#xE8FB;"
                                            FontSize="22"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Locked: muted circle -->
                                    <Border
                                        Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                        CornerRadius="22"
                                        Visibility="{x:Bind IsLocked, Converter={StaticResource BoolToVisibility}}">
                                        <FontIcon
                                            Glyph="&#xE72E;"
                                            FontSize="22"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>
                                </Border>

                                <!-- Title, description, criteria -->
                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="{x:Bind Title}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock
                                        Text="{x:Bind Description}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                        <FontIcon
                                            Glyph="&#xE946;"
                                            FontSize="10"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Text="{x:Bind Criteria}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- "Unlocked" status pill -->
                                <Border
                                    Grid.Column="2"
                                    Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind IsUnlocked, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock
                                        Text="Unlocked"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                </Border>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
