<Page
    x:Class="VibeCoders.Views.FocusModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Black">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

            <TextBlock Text="Push Day"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />


            <StackPanel Margin="0,10">

                <TextBlock Text="Exercise Name" 
                   Foreground="White" 
                   FontSize="24"/>

                <TextBlock Text="Previous best"
                   Foreground="Gray"
                   FontSize="16"
                   Margin="0,0,0,5"/>

                <ItemsRepeater>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ActiveSetViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind SetIndex}" Foreground="White"/>
                                <TextBlock Text="{x:Bind TargetReps}" Foreground="White"/>
                                <TextBlock Text="{x:Bind TargetWeight}" Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>

            <ItemsRepeater>
                <ItemsRepeater.ItemsSource>
                    <x:Array Type="StackPanel">

                        <!-- Exercise 1 -->
                        <StackPanel Margin="0,10">
                            <TextBlock Text="Bench Press"
                                       Foreground="White"
                                       FontSize="24"/>

                            <!-- Sets -->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Set 1:" Foreground="Gray"/>
                                    <TextBlock Text="Reps: 10" Foreground="White"/>
                                    <TextBlock Text="Weight: 80kg" Foreground="White"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Set 2:" Foreground="Gray"/>
                                    <TextBlock Text="Reps: 8" Foreground="White"/>
                                    <TextBlock Text="Weight: 85kg" Foreground="White"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Exercise 2 -->
                        <StackPanel Margin="0,10">
                            <TextBlock Text="Incline Dumbbell Press"
                                       Foreground="White"
                                       FontSize="24"/>

                            <!-- Sets -->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Set 1:" Foreground="Gray"/>
                                    <TextBlock Text="Reps: 12" Foreground="White"/>
                                    <TextBlock Text="Weight: 24kg" Foreground="White"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Set 2:" Foreground="Gray"/>
                                    <TextBlock Text="Reps: 10" Foreground="White"/>
                                    <TextBlock Text="Weight: 26kg" Foreground="White"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </x:Array>
                </ItemsRepeater.ItemsSource>
            </ItemsRepeater>
            
            

            <Button Content="Finish Workout"
                    Width="200"
                    Height="50"/>
        </StackPanel>
    </Grid>
</Page>