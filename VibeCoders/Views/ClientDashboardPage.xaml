<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VibeCoders.Views.ClientDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:VibeCoders.ViewModels"
    xmlns:models="using:VibeCoders.Models.Analytics"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid>
        <!-- Left-align content: narrow MaxWidth inside ScrollViewer is centered by default and leaves a huge gap next to the nav pane. -->
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Top">
            <StackPanel
                Padding="20,20,28,32"
                Spacing="28"
                HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- Header row -->
                <Grid>
                    <TextBlock
                        Text="Analytics Dashboard"
                        Style="{StaticResource TitleTextBlockStyle}"
                        VerticalAlignment="Center" />
                    <Button
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ── Achievements Preview ─────────────────────────────────── -->
<StackPanel Spacing="12">
    <Grid>
        <TextBlock
            Text="Achievements"
            Style="{StaticResource SubtitleTextBlockStyle}"
            VerticalAlignment="Center" />
        <HyperlinkButton
            Content="See all"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Click="SeeAllAchievements_Click" />
    </Grid>

    <!-- Horizontal scrolling preview strip (first ~5 badges) -->
    <ScrollViewer
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Enabled"
        VerticalScrollMode="Disabled">
        <ItemsRepeater ItemsSource="{x:Bind DashboardViewModel.RecentAchievements, Mode=OneWay}">
            <ItemsRepeater.Layout>
                <StackLayout Orientation="Horizontal" Spacing="12" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="models:Achievement">
                    <Border
                        Width="140"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,14">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <Border
                                Width="44" Height="44" CornerRadius="22"
                                HorizontalAlignment="Center"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                                <FontIcon
                                    Glyph="{x:Bind Icon}" FontSize="20"
                                    Foreground="White"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <TextBlock
                                Text="{x:Bind Name}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <FontIcon
                                Glyph="&#xE73E;" FontSize="12"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                HorizontalAlignment="Center"
                                Visibility="{x:Bind IsUnlocked, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </ScrollViewer>
</StackPanel>

                <!-- KPI Summary Cards -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">

                    <!-- Total Workouts -->
                    <Border
                        Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Total Workouts"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE81E;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.TotalWorkouts, Mode=OneWay}"
                                       Style="{StaticResource TitleLargeTextBlockStyle}"
                                       Margin="0,12,0,0" />
                        </Grid>
                    </Border>

                    <!-- Active Time (7 Days) -->
                    <Border
                        Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Active Time (7 Days)"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE121;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.ActiveTimeSevenDaysDisplay, Mode=OneWay}"
                                       Style="{StaticResource TitleLargeTextBlockStyle}"
                                       Margin="0,12,0,0" />
                        </Grid>
                    </Border>

                    <!-- Preferred Workout -->
                    <Border
                        Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Preferred Workout"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" Glyph="&#xE734;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Grid>
                            <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.PreferredWorkoutDisplay, Mode=OneWay}"
                                       Style="{StaticResource TitleTextBlockStyle}"
                                       Margin="0,16,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Consistency Chart (control added in code-behind; hidden when empty) -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24"
                    Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="4-Week Consistency"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ProgressRing
                                HorizontalAlignment="Right"
                                IsActive="{x:Bind ViewModel.IsLoadingChart, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsLoadingChart, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                Width="20" Height="20" />
                        </Grid>

                        <Grid x:Name="ChartContainer" Height="240" Margin="0,16,0,0" />
                    </StackPanel>
                </Border>

                <!-- Workout History -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Workout History"
                               Style="{StaticResource SubtitleTextBlockStyle}" />

                    <!-- Header Row for the history list -->
                    <Grid Padding="16,8" ColumnDefinitions="2*,*,*"
                          Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <TextBlock Text="WORKOUT" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="DATE" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="2" Text="DURATION" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <ItemsRepeater
                        ItemsSource="{x:Bind ViewModel.HistoryItems, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkoutHistoryItemViewModel">
                                <Expander
                                    IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    CornerRadius="4"
                                    Margin="0,0,0,8">
                                    <Expander.Header>
                                        <Grid ColumnDefinitions="2*,*,*,Auto" Padding="0,8">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <FontIcon Glyph="&#xE14C;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{x:Bind Title}"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{x:Bind DateLine}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind DurationLine}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="3"
                                                    Background="{x:Bind IntensityBrush}"
                                                    CornerRadius="4"
                                                    Padding="8,2"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{x:Bind IntensityTag}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Expander.Header>
                                    <Expander.Content>
                                        <StackPanel Padding="0,4,0,12">
                                            <ProgressRing
                                                IsActive="{x:Bind IsLoadingDetail, Mode=OneWay}"
                                                Visibility="{x:Bind IsLoadingDetail, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                Width="20" Height="20"
                                                HorizontalAlignment="Center"
                                                Margin="0,8" />

                                            <!-- Total Calories Burned Summary -->
                                            <Border Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                                    CornerRadius="4"
                                                    Padding="16,12"
                                                    Margin="44,8,0,12"
                                                    Visibility="{x:Bind IsLoadingDetail, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <FontIcon Glyph="&#xE91B;" FontSize="20"
                                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}">
                                                        <Run Text="Total Calories Burned: "/>
                                                        <Run Text="{x:Bind TotalCaloriesBurned}" FontWeight="Bold"/>
                                                        <Run Text=" kcal"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <!-- Calories by Exercise Section -->
                                            <StackPanel Margin="44,0,0,16"
                                                       Visibility="{x:Bind IsLoadingDetail, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                <TextBlock Text="Calories by Exercise"
                                                          Style="{StaticResource BodyStrongTextBlockStyle}"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                          Margin="0,0,0,8"/>
                                                <ItemsControl ItemsSource="{x:Bind ExerciseCalories, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:ExerciseCalorieInfo">
                                                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <FontIcon Glyph="&#xE9C9;" FontSize="14"
                                                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                    <TextBlock Text="{x:Bind ExerciseName}"
                                                                              Style="{StaticResource BodyTextBlockStyle}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                                    <TextBlock Text="{x:Bind CaloriesBurned}"
                                                                              Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                                    <TextBlock Text="kcal"
                                                                              Style="{StaticResource CaptionTextBlockStyle}"
                                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                              VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <Grid ColumnDefinitions="3*,*,*,*" Margin="44,0,0,8"
                                                  Visibility="{x:Bind IsLoadingDetail, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                <TextBlock Text="Exercise" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="1" Text="Set" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="2" Text="Reps" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Grid.Column="3" Text="Weight" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{x:Bind Sets, Mode=OneWay}" Margin="44,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:WorkoutSetRow">
                                                        <Grid ColumnDefinitions="3*,*,*,*" Padding="0,6">
                                                            <TextBlock Text="{x:Bind ExerciseName}" Style="{StaticResource BodyTextBlockStyle}" />
                                                            <TextBlock Grid.Column="1" Text="{x:Bind SetIndex}" Style="{StaticResource BodyTextBlockStyle}" />
                                                            <TextBlock Grid.Column="2" Text="{x:Bind RepsDisplay}" Style="{StaticResource BodyTextBlockStyle}" />
                                                            <TextBlock Grid.Column="3" Text="{x:Bind WeightDisplay}" Style="{StaticResource BodyTextBlockStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander.Content>
                                </Expander>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Loading spinner for history -->
                    <ProgressRing
                        IsActive="{x:Bind ViewModel.IsLoadingHistory, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoadingHistory, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        Width="32" Height="32"
                        HorizontalAlignment="Center"
                        Margin="0,16" />

                    <!-- Empty state -->
                    <StackPanel
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Padding="0,48">
                        <FontIcon Glyph="&#xE787;" FontSize="56"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No workouts recorded yet"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Complete a workout to see your analytics and history here."
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Pagination controls -->
                    <Grid
                        ColumnDefinitions="Auto,*,Auto"
                        Margin="0,16,0,0"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <Button Content="Previous"
                                Command="{x:Bind ViewModel.PreviousPageCommand}"
                                IsEnabled="{x:Bind ViewModel.CanGoPrevious, Mode=OneWay}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE76B;" FontSize="12" />
                                        <TextBlock Text="Previous" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.PageDisplayText, Mode=OneWay}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Command="{x:Bind ViewModel.NextPageCommand}"
                                IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Next" />
                                        <FontIcon Glyph="&#xE76C;" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
