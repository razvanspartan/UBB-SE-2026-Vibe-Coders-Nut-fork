<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VibeCoders.Views.ClientProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VibeCoders.Views"
    xmlns:models="using:VibeCoders.Models"
    xmlns:vm="using:VibeCoders.ViewModels">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Exercises -->
        <ScrollViewer Grid.Column="0" Padding="12">
            <StackPanel>
                <TextBlock Text="Assigned Exercises" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>

                <ItemsRepeater ItemsSource="{Binding LoggedExercises}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:LoggedExercise">
                            <Expander Header="{x:Bind ExerciseName}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind AdjustmentNote}" FontStyle="Italic" Foreground="Gray"/>
                                    <TextBlock Text="{x:Bind TargetMuscles}" />

                                    <!-- Nested Sets -->
                                    <ItemsRepeater ItemsSource="{x:Bind Sets}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:LoggedSet">
                                                <StackPanel Orientation="Horizontal" Margin="8,2">
                                                    <TextBlock Text="{x:Bind SetNumber}" Width="30"/>
                                                    <TextBlock Text="{x:Bind TargetReps}" Width="50"/>
                                                    <TextBlock Text="{x:Bind ActualReps}" Width="50"/>
                                                    <TextBlock Text="{x:Bind TargetWeight}" Width="60"/>
                                                    <TextBlock Text="{x:Bind ActualWeight}" Width="60"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>

        <!-- Right: Nutrition -->
        <ScrollViewer Grid.Column="1" Padding="12">
            <StackPanel>
                <TextBlock Text="Nutrition Plan" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>

                <ItemsRepeater ItemsSource="{Binding Meals}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:Meal">
                            <Expander Header="{x:Bind Name}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Ingredients:" FontWeight="Bold" />
                                    <ItemsRepeater ItemsSource="{x:Bind Ingredients}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <TextBlock Text="• {x:Bind}" Margin="12,0"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                    <TextBlock Text="Instructions:" FontWeight="Bold" Margin="0,4,0,0"/>
                                    <TextBlock Text="{x:Bind Instructions}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
