<UserControl x:Class="VibeCoders.Views.MealDetailCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="400">

	<!--Card Container -->
	<Border Background="#FFFFFF" CornerRadius="8" Padding="16" Margin="0,8"
            BorderBrush="#E5E7EB" BorderThickness="1">
		<Border.Effect>
			<DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2" Color="Black"/>
		</Border.Effect>

		<StackPanel>
			<!-- Meal Name -->
			<TextBlock Text="{Binding Name}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,0,0,12"/>

			<!-- Ingredients -->
			<TextBlock Text="Ingredients:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#4B5563"
                       Margin="0,0,0,4"/>

			<!--  List of Ingredients -->
			<ItemsControl ItemsSource="{Binding Ingredients}" Margin="0,0,0,16">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal" Margin="8,3,0,3">
							<TextBlock Text="•" Foreground="#005FB8" Margin="0,0,8,0" FontWeight="Bold" FontSize="16"/>
							<TextBlock Text="{Binding}" Foreground="#374151" FontSize="14" VerticalAlignment="Center"/>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- Instructions -->
			<TextBlock Text="Preparation Instructions:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#4B5563"
                       Margin="0,0,0,4"/>

			<!-- Instructions -->
			<TextBlock Text="{Binding Instructions}"
                       TextWrapping="Wrap"
                       Foreground="#4B5563"
                       LineHeight="20"
                       FontSize="14"/>
		</StackPanel>
	</Border>
</UserControl>