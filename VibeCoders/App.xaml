<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="VibeCoders.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VibeCoders"
    xmlns:converters="using:VibeCoders.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:BoolNegateConverter x:Key="BoolNegate" />
            <converters:StringToBoolConverter x:Key="StringToBool" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacity" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
